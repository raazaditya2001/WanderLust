<% layout("/layouts/boilerplate")%> 

<div class="filter">
<% for(filter of categories) { %>
    <a href="/listings?category=<%=filter.name%>">
    <div class="filteritems">
        <div> <%= filter.icon %></div>
        <p><%= filter.name %></p>
    </div>
</a>
<% } %>
</div>

    <!-- <div class="form-check form-switch offset-10">
  <input class="form-check-input" type="checkbox" role="switch" id="price">
  <label class="form-check-label" for="price">Price After Taxes</label>
</div> -->


    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
         <%for(let listing of allListings){%>

        <a href="/listings/<%=listing._id%>" class="listing-link">
            <div class="listing-card col">
  <img src="<%=listing.image.url%>" class="card-img-top" alt="listing image" style="height:20rem">
  <div class="card-body">
    <p class="card-text">
       <B><%=listing.title%></B>
        <br>
        ₹ <%=listing.price.toLocaleString("en-IN")%>/night
    </p>
  </div>
</div>
        </a>

<%}%>
    </div>

    <script>
        let priceCheckBox = document.querySelector("#price");
        priceCheckBox.addEventListener("click",()=>{
            console.log("checkbox clicked");
        })

    </script>
 




