<% layout("/layouts/boilerplate")%>

<div class="row">
        <div class="col-8 offset-2">
    <br>
    <h2>Register Yourself</h2>
    <br>

    <form action="/user/signup" method="post" novalidate class="needs-validation">
          
          <div class="mb-3">
            <label for="user[username]" class="form-label" >Username</label>
            <input name="user[username]" class="form-control" required placeholder="Enter Username">
            <div class="invalid-feedback">
                Please enter username
            </div>
          </div>

        <div class="mb-3">
            <label for="user[email]" class="form-label">Email</label>
            <input name="user[email]" class="form-control" required />
            <div class="invalid-feedback">
                Write Email
            </div>
        </div>

        <div class="mb-3">
            <label for="user[password]" class="form-label">Password</label>
            <input name="user[password]" class="form-control" type="password" required placeholder="Enter Password">
            <div class="invalid-feedback">
                Enter valid Password
            </div>
        </div>

        
        
        <button type="submit" class="btn btn-primary">Register</button>
        <br><br><br>
        
        

    </form>
    </div>
    </div>