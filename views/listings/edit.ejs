<% layout("/layouts/boilerplate")%>

     
    <div class="row">
        <div class="col-8 offset-2">
    <br>
    <h2>Edit your Listing</h2>
    <br>

    <form action="/listings/<%= listing._id%>?_method=PUT" method="post" novalidate class="needs-validation" enctype="multipart/form-data">
          
          <div class="mb-3">
            <label for="listing[title]" class="form-label">Title</label>
            <input name="listing[title]" class="form-control" value="<%=listing.title%>" required>
            <div class="invalid-feedback">
                Please enter title
            </div>
            </div>
        

        <div class="mb-3">
            <label for="listing[description]" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" required><%=listing.description%></textarea>
            <div class="invalid-feedback">
                Write short description
            </div>
        </div>

        <div class="mb-3">
            <label for="listing[price]" class="form-label">Price</label>
            <input name="listing[price]" class="form-control" type="number" value="<%=listing.price%>" required>
            <div class="invalid-feedback">
                Enter vaild price
            </div>
        </div>

        <div class="mb-3">
            <label for="listing[location]" class="form-label">Location</label>
            <input name="listing[location]" class="form-control" value="<%=listing.location%>" required>
            <div class="invalid-feedback">
                Enter valid location
            </div>
        </div>
          
        <div class="mb-3">
            <img src="<%=compImg%>"  alt="listingImg"> <br>
            <label for="listing[image]" class="form-label">Upload image</label>
            <input name="listing[image]" class="form-control" type="file" >
        </div>
        
        <button type="submit" class="btn btn-primary">Edit</button>
        <br><br><br>
        
        

    </form>
    </div>
</div>
   

